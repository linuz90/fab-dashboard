# Optional local development overrides.
# Copy to .env in the repo root, or put connector secrets in
# ~/.config/fab-dashboard/.env for your real dashboard.

# Run the API on a different local port.
# FAB_DASHBOARD_PORT=7893

# Bind only to localhost unless you intentionally expose the dashboard.
FAB_DASHBOARD_HOST=127.0.0.1
FAB_DASHBOARD_ALLOWED_HOSTS=localhost,127.0.0.1

# Set when serving behind a trusted local tunnel, reverse proxy, or Tailscale name.
# FAB_DASHBOARD_PUBLIC_ORIGIN=http://localhost:7893

# Use ignored repo-local homes for demo work.
# FAB_DASHBOARD_HOME=./local/demo
# FAB_DASHBOARD_STATE_HOME=./local/state

# Example connector secrets. Keep real values out of git.
# WEATHER_API_KEY=
# MUSIC_API_CLIENT_ID=
# MUSIC_API_CLIENT_SECRET=
