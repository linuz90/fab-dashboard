{
  "name": "fab-dashboard",
  "version": "0.1.0",
  "private": true,
  "description": "Local-first, connector-backed personal dashboard engine.",
  "license": "MIT",
  "author": "Fabrizio Rinaldi",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/linuz90/fab-dashboard.git"
  },
  "bugs": {
    "url": "https://github.com/linuz90/fab-dashboard/issues"
  },
  "homepage": "https://github.com/linuz90/fab-dashboard#readme",
  "keywords": [
    "dashboard",
    "personal-dashboard",
    "local-first",
    "connectors",
    "cards",
    "react",
    "bun",
    "vite"
  ],
  "type": "module",
  "packageManager": "bun@1.3.13",
  "bin": {
    "fab-dashboard": "./bin/fab-dashboard"
  },
  "scripts": {
