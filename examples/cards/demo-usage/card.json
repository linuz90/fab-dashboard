    },
    { "type": "divider" },
    { "type": "text", "text": "Agent", "variant": "caption" },
    {
      "type": "rows",
      "rows": [
        { "label": "5h", "icon": "bot", "valuePath": "demo-usage.agent5h", "hintPath": "demo-usage.agent5hReset", "progressPath": "demo-usage.agent5hPct", "sparklinePath": "demo-usage.agentHistory" },
        { "label": "Week", "icon": "calendar-range", "valuePath": "demo-usage.agentWeek", "hintPath": "demo-usage.agentWeekReset", "progressPath": "demo-usage.agentWeekPct" }
      ]
    },
    { "type": "divider" },
