      "rows": [
        { "label": "Sleep", "icon": "moon-star", "valuePath": "demo-health.sleep" },
        { "label": "Steps", "icon": "footprints", "valuePath": "demo-health.steps", "progressPath": "demo-health.stepsPct", "sparklinePath": "demo-health.stepsTrend", "sparklineVariant": "bars" },
        { "label": "Heart", "icon": "heart-pulse", "valuePath": "demo-health.heart", "sparklinePath": "demo-health.hrvTrend" }
      ]
    }
  ]
