          ]
        },
        {
          "id": "recent",
          "label": "Recent",
          "blocks": [
            { "type": "list", "variant": "timeline", "path": "demo-sim-racing.recent", "icon": "trophy", "titlePath": "title", "metaPath": "result", "textPath": "text", "tonePath": "tone", "limit": 4 }
          ]
        }
      ]
    }
  ]
}
